# ── clinical-rules-mcp-server environment ──────────────────────────────────
# Track 1 (Claude Desktop) needs NONE of these. The pure-database tools
# (list_payers, get_coverage_policy, check_auth_requirements) run with zero
# configuration. Only flag_documentation_gaps and the Track 2 pipeline need
# a live model — and even those run with MOCK_LLM=true.

# Required only when flag_documentation_gaps / Track 2 run with MOCK_LLM=false.
ANTHROPIC_API_KEY=

# When true, flag_documentation_gaps returns the deterministic fixture in
# data/mock-gap-analysis.json instead of calling Claude. Forced true in tests.
MOCK_LLM=true

# Port for the Streamable HTTP MCP endpoint and the /health tool-list route.
MCP_PORT=3001

# Route Claude calls through AWS Bedrock instead of the direct Anthropic API.
# This only changes the model endpoint; no infrastructure is provisioned.
USE_BEDROCK=false

# Model id used by flag_documentation_gaps when MOCK_LLM=false.
GAP_ANALYSIS_MODEL=claude-sonnet-4-6
